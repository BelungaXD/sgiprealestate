{
  "name": "sgip-real-estate",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4000 --webpack",
    "dev:turbo": "next dev -p 4000",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "analyze": "ANALYZE=true next build --webpack",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts",
    "import:properties": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/import-properties-from-folders.ts",
    "cleanup:incoming": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/cleanup-incoming-uploads.ts"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.1.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^5.22.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@types/formidable": "^3.5.1",
    "formidable": "^3.5.4",
    "i18next": "^26.0.8",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "next-i18next": "^16.0.5",
    "prisma": "^5.22.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "^7.73.1",
    "react-i18next": "^17.0.4",
    "sharp": "^0.34.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.39",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.5.0",
    "cssnano": "^7.1.7",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "rimraf": "^5.0.0",
    "glob": "^13.0.6",
    "jsdom": "^29.0.2"
  },
  "prisma": {
    "seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts"
  },
  "browserslist": {
    "production": [
      "defaults",
      "not IE 11",
      "not op_mini all",
      "Chrome >= 92",
      "Firefox >= 90",
      "Safari >= 15.4",
      "Edge >= 92"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
