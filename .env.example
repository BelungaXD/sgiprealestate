# ============================================================================
# SGIP Real Estate - Environment Variables Example
# ============================================================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control
# This file is synchronized with production .env structure

# ============================================================================
# Domain Configuration
# ============================================================================
# For production: set DOMAIN to canonical domain (e.g. sgipreal.com) so
# nginx-microservice deploy-smart.sh can route this domain to the app.
# If DOMAIN is missing, https://sgipreal.com may show the default landing page.
DOMAIN=
# Deploy service name (must be sgiprealestate). Do NOT set to the domain (sgipreal.com)
# or deploy scripts will fail with "Domain not found in registry for service: sgipreal.com"
SERVICE_NAME=sgiprealestate
DEFAULT_DOMAIN_SUFFIX=

# ============================================================================
# Database Server (Shared PostgreSQL)
# ============================================================================
# For Docker network access (production)
# Configured in database-server/.env: DB_SERVER_PORT (default: 5432)
# For local development, use: DB_HOST=localhost
DB_HOST=
DB_PORT=
DB_USER=
# IMPORTANT: Currently using admin password. Consider creating dedicated user with ./scripts/create-database.sh
DB_PASSWORD=
DB_NAME=

# Prisma requires DATABASE_URL
# docker-compose will expand the variables below
# For local development, use: DATABASE_URL=postgresql://user:password@localhost:5432/dbname?schema=public
DATABASE_URL=

# ============================================================================
# Logging Service (Shared)
# ============================================================================
# Configured in logging-microservice/.env: PORT (default: 3367)
# Production URL: https://logging.statex.cz
# Docker Network URL: http://logging-microservice:3367
# For local development, you can use production URL or disable logging
LOGGING_SERVICE_URL=

# ============================================================================
# Application Configuration
# ============================================================================
NODE_ENV=
PORT=
# Optional: minutes before scripts/cleanup-incoming-uploads.ts removes stale upload batches (default 30)
INCOMING_MAX_AGE_MINUTES=
NEXT_PUBLIC_SITE_URL=
PORT_BLUE=
PORT_GREEN=

# ============================================================================
# Other Configuration
# ============================================================================
ADMIN_EMAIL=

# Admin panel at /admin (and localized routes) — server-side only (never NEXT_PUBLIC_*)
# Prefer ADMIN_SESSION_SECRET (>=16 chars, e.g. openssl rand -hex 32). If unset, a stable
# secret is derived from ADMIN_PASSWORD so login works when only password is set.
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# ============================================================================
# Analytics (Local Development)
# ============================================================================
NEXT_PUBLIC_GTM_ID=

# ============================================================================
# Communication (Local Development)
# ============================================================================
NEXT_PUBLIC_WHATSAPP_NUMBER=
# e.g. https://t.me/+971505807871 (used when NEXT_PUBLIC_TELEGRAM_USERNAME is unset)
NEXT_PUBLIC_TELEGRAM_URL=
NEXT_PUBLIC_TELEGRAM_USERNAME=
# Public contact email shown on site (default in code: admin@sgipreal.com)
NEXT_PUBLIC_CONTACT_EMAIL=
# Optional logo paths (defaults: /images/sgip_logo_dark.png header, /images/sgip_logo_bright.png footer)
NEXT_PUBLIC_LOGO_HEADER=
NEXT_PUBLIC_LOGO_FOOTER=
# Team mailboxes (create in your mail host; shown on Contact page)
NEXT_PUBLIC_EMAIL_RU=
NEXT_PUBLIC_EMAIL_ALEX=
NEXT_PUBLIC_EMAIL_ELZA=
# Social profile URLs (optional; footer/contact globe links to NEXT_PUBLIC_SITE_URL)
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_YOUTUBE_URL=
NEXT_PUBLIC_LINKEDIN_URL=

# ============================================================================
# Maps (Local Development)
# ============================================================================
# Get your key from Google Cloud Console
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ============================================================================
# Integrations (optional)
# ============================================================================

# ============================================================================
# Server URL for Image Proxying (Local Development)
# ============================================================================
# Set this to your production server URL to proxy images from server
# Example: NEXT_PUBLIC_SERVER_URL=https://sgipreal.com
NEXT_PUBLIC_SERVER_URL=
